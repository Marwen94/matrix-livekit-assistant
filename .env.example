# ── DOMAIN CONFIGURATION ─────────────────────────────────────────────
DOMAIN=example.com                      # Base domain for the deployment
EMAIL=admin@example.com                 # Email for Let's Encrypt certificates
MATRIX_SUBDOMAIN=matrix                 # matrix.example.com
LIVEKIT_SUBDOMAIN=livekit               # livekit.example.com
CALL_SUBDOMAIN=call                     # call.example.com
CLOUDFLARE_TUNNEL_TOKEN=                # Tunnel token from Cloudflare Zero Trust

# ── LLM (OLLAMA) ─────────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:3b                 # Default LLM model (CPU friendly)

# ── LIVEKIT ──────────────────────────────────────────────────────────
LIVEKIT_KEYS=devkey: devsecret                # LiveKit Keys (keep secret) needs to be in the format of 'devkey: devsecret'


# ── SYNAPSE / POSTGRES ───────────────────────────────────────────────
SYNAPSE_SIGNING_KEY=                    # Generate with: docker run --rm matrixdotorg/synapse generate (see README.md)
POSTGRES_PASSWORD=replace_me_postgres   # Database password
MACAROON_SECRET_KEY=replace_me_macaroon_secret         # Generate with: openssl rand -hex 32
REGISTRATION_SHARED_SECRET=replace_me_registration     # Generate with: openssl rand -hex 32
FORM_SECRET=replace_me_form_secret                     # Generate with: openssl rand -hex 32
SYNAPSE_REPORT_STATS=no                 # Whether to report stats to Matrix.org

# ── STT SERVICE (Whisper) ────────────────────────────────────────────
STT_MODEL=large-v3-turbo                # Faster-whisper model size
STT_MIN_CHUNK_SIZE=1.0                  # Real-time streaming chunk size in seconds
STT_COMPUTE_TYPE=int8                   # CPU-optimized quantization (int8, float32)
STT_THREADS=4                           # Number of CPU threads for STT

# ── TTS SERVICE (Kokoro) ─────────────────────────────────────────────
TTS_VOICE=af_heart                      # Default TTS voice (e.g., af_heart, am_adam)

# ── AI AGENT ─────────────────────────────────────────────────────────
LLM_SYSTEM_PROMPT=You are a helpful AI assistant in a group voice call. Keep answers concise - 2 to 3 sentences maximum. Avoid markdown, bullet points, and special characters since your response will be spoken aloud. Only answer question when you are explicitly asked to using the phrase `Assistant, answer the question`.
LOG_TRANSCRIPTS=false                     # Set true only for temporary debugging
ASSISTANT_USER_ID=@assistant:example.com # Matrix ID of the AI assistant
